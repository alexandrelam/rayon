{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/desktop/src/**/*",
      "apps/desktop/vite.config.ts",
      "eslint.config.mjs",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/dist-ssr/**",
      "!**/coverage/**",
      "!**/target/**",
      "!**/src-tauri/gen/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
